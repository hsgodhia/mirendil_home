         if weighted:
             wd += ndiff
         else:
@@ -223,13 +236,28 @@ def pk(ref, hyp, k=None, boundary="1"):
     :rtype: float
     """
 
+    if len(ref) != len(hyp):
+        raise ValueError("Segmentations have unequal length")
     if k is None:
         k = int(round(len(ref) / (ref.count(boundary) * 2.0)))
+    if k < 0:
+        raise ValueError("Window width k should not be negative")
 
     err = 0
